{
  "Markdown attr_list (class, id)": {
    "prefix": "[",
    "body": [
      "[${1:text}]{${2:.class #id}}"
    ],
    "description": "Markdown attr_list extension for custom CSS classes and IDs"
  },
  "Mono Component: badge": {
    "prefix": "@[badge",
    "body": [
      "@[badge](color: \"${1:blue}\", soft: \"${2:true}\", outline: \"${3:true}\")"
    ],
    "description": "Badge component"
  },
  "Mono Component: icon": {
    "prefix": "@[icon",
    "body": [
      "@[icon](name: \"${1:lucide-icon-name}\", size: \"${2:24}\", color: \"${3:currentColor}\")"
    ],
    "description": "Icon component using Lucide"
  },
  "Mono Component: row": {
